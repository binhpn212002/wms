# Dán khối dưới vào CUỐI file .env của bạn (không sửa các biến đã có).
# Đổi giá trị placeholder cho phù hợp môi trường.

# AWS (Nest gửi SQS; CLI/SST)
AWS_REGION=ap-southeast-1
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Cảnh báo tồn kho thấp — Nest
INTERNAL_API_KEY=change-me-long-random
LOW_STOCK_QUEUE_URL=
# LOW_STOCK_ALERT_EMAILS=ops@example.com,manager@example.com

# SST + Lambda (cùng thư mục wms-backend)
LOW_STOCK_SCHEDULER_ENABLED=false
LOW_STOCK_SCAN_SCHEDULE=cron(0 8 * * ? *)
LOW_STOCK_SCHEDULE_TIMEZONE=Asia/Ho_Chi_Minh
LOW_STOCK_SCHEDULER_RETRIES=2
WMS_INTERNAL_LOW_STOCK_SCAN_URL=http://localhost:3000/api/v1/internal/low-stock/scan
SES_FROM_EMAIL=
SES_REGION=ap-southeast-1
