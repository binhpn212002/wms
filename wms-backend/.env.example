# Application
NODE_ENV=development
PORT=3000

# JWT (auth)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Firebase configuration — must match the frontend (see wms-frontend/.env.example)
FIREBASE_API_KEY=AIzaSyAdYlIwdC026h-cCG4yDjdH_6ZW3xBqHI8
FIREBASE_AUTH_DOMAIN=warehousemanagement-405f6.firebaseapp.com
FIREBASE_PROJECT_ID=warehousemanagement-405f6
FIREBASE_STORAGE_BUCKET=warehousemanagement-405f6.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=404032166380
FIREBASE_APP_ID=1:404032166380:web:48bf203be06ddf2d1788c9
FIREBASE_MEASUREMENT_ID=G-9Z3WWJJQDX

# Seed 3 users (admin / warehouse / manager) — idempotent (bỏ qua username/phone đã có)
# Firebase Admin — không dán JSON xuống nhiều dòng sau dấu = (dotenv sẽ sai). Chi tiết: credentials/README.md
# - File (khuyến nghị): FIREBASE_SERVICE_ACCOUNT_JSON_FILE=./credentials/firebase-adminsdk.json
# - Trong .env (một dòng): FIREBASE_SERVICE_ACCOUNT_JSON_B64=<Base64 UTF-8 của cả file JSON>
#   PowerShell: [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes((Get-Content -Raw 'key.json')))
# - Một dòng minify: FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}


# PostgreSQL (see src/database/typeorm.config.ts)
# Image postgres:16-alpine: dùng user `postgres` là ổn định. Nếu đổi user/mật khẩu sau lần init,
# cần xóa volume DB rồi tạo lại: docker compose down -v && docker compose up -d postgres
# App trên host: localhost. App trong compose: host = postgres.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=wms

# Redis primary (read/write; docker service name: redis)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# Redis read replica (optional; docker service name: redis-replica — port 6379 inside network)
REDIS_REPLICA_HOST=localhost
REDIS_REPLICA_PORT=6380

# --- Cảnh báo tồn kho thấp (API nội bộ + SQS + Lambda + SES) ---
# Khóa gọi POST /api/v1/internal/low-stock/scan (Lambda Scheduler và chỉ định khác phải gửi đúng header)
INTERNAL_API_KEY=change-me-long-random
# URL queue SQS (sau sst deploy: copy output lowStockQueueUrl, hoặc từ AWS console)
LOW_STOCK_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/404032166380/LowStockQueue
# Email nhận cảnh báo (ưu tiên hơn danh sách user ACTIVE có email trong DB). Phân tách bằng dấu phẩy.
# LOW_STOCK_ALERT_EMAILS=ops@example.com,manager@example.com

# SST / AWS — EventBridge Scheduler + Lambda scanner (file .env cạnh sst.config.ts)
# LOW_STOCK_SCHEDULER_ENABLED=true
# Mặc định trong code: cron(0 8 * * ? *) — 08:00 mỗi ngày theo LOW_STOCK_SCHEDULE_TIMEZONE
# LOW_STOCK_SCAN_SCHEDULE=cron(0 8 * * ? *)
# LOW_STOCK_SCHEDULE_TIMEZONE=Asia/Ho_Chi_Minh
# LOW_STOCK_SCHEDULER_RETRIES=2
# URL public tới API Nest (Lambda POST + header x-internal-api-key)
# WMS_INTERNAL_LOW_STOCK_SCAN_URL=https://your-api.example.com/api/v1/internal/low-stock/scan
# INTERNAL_API_KEY=phải trùng với biến INTERNAL_API_KEY của Nest phía trên
# SES: địa chỉ đã verify trong SES (cùng region deploy Lambda hoặc chỉnh SES_REGION)
# SES_FROM_EMAIL=noreply@verified-domain.example.com
# SES_REGION=ap-southeast-1
